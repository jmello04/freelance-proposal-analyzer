# Normaliza line endings para LF em todos os arquivos de texto
* text=auto eol=lf

# Python
*.py    text eol=lf
*.pyi   text eol=lf

# Web
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# Config
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf
*.env   text eol=lf

# Docs
*.md    text eol=lf
*.txt   text eol=lf

# Shell / Make
Makefile      text eol=lf
Dockerfile    text eol=lf
*.sh          text eol=lf

# Binários — não tocar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
*.zip   binary
